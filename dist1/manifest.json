{
  "manifest_version": 3,
  "name": "Select Hanguk",
  "version": "1.0.0",
  "description": "국가 선택 UI에서 대한민국(한국) 옵션을 상단으로 이동하고 선택하기 쉽게 합니다.",
  "permissions": ["storage", "tabs"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "src/background/service_worker.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "src/content/detect.js",
        "src/content/shadowWalk.js",
        "src/content/optimizeSelect.js",
        "src/content/optimizeCustom.js",
        "src/content/events.js",
        "src/content/scheduler.js",
        "src/content/index.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "action": {
    "default_popup": "src/ui/popup.html",
    "default_icon": {
      "16": "assets/icon16.png",
      "48": "assets/icon48.png",
      "128": "assets/icon128.png"
    }
  },
  "options_ui": {
    "page": "src/ui/options.html"
  },
  "icons": {
    "16": "assets/icon16.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  }
}
